{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/socket.io/(.*)", "dest": "/server.js" },
    { "src": "/stats_Dashboard.html", "dest": "/server.js" },
    { "src": "/admin_dashboard.html", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}